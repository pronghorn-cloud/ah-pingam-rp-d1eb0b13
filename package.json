{
  "name": "ah-pingam-rp",
  "version": "1.0.0",
  "description": "PingAM Analytics and Reporting Dashboard - Power Platform Compliant",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm start",
    "build": "cd client && npm run build",
    "test": "jest --coverage",
    "test:server": "jest --testPathPattern=server --coverage",
    "test:client": "cd client && npm test",
    "test:e2e": "jest --testPathPattern=e2e",
    "lint": "eslint server/ client/src/",
    "db:init": "node server/database/init.js",
    "docker:build": "docker build -t ah-pingam-rp:latest .",
    "docker:build:ppc64le": "docker buildx build --platform linux/ppc64le -t ah-pingam-rp:latest-ppc64le ."
  },
  "keywords": [
    "pingam",
    "analytics",
    "dashboard",
    "openshift",
    "power-platform",
    "ppc64le"
  ],
  "author": "AH Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
