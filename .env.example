# Server Configuration
NODE_ENV=development
PORT=3001

# Database
DB_PATH=./data

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_PATH=/var/log/app

# Security (generate secure values for production)
SESSION_SECRET=your-secure-session-secret

# JWT Authentication (E-014)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Default Superadmin Credentials (change these in production!)
# These are used to seed the initial superadmin user on first run
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=superadmin@localhost
SUPERADMIN_PASSWORD=SuperAdmin@123

# PingAM Instances Encryption Key (for encrypting passwords/API keys at rest)
# Generate a secure random key for production!
PINGAM_ENCRYPTION_KEY=your-secure-encryption-key-change-in-production

# Legacy PingAM Connection (E-020) - Consider using PingAM Instances API instead
PINGAM_URL=https://your-pingam-server.example.com
PINGAM_REALM=/alpha
PINGAM_ADMIN_USERNAME=amadmin
PINGAM_ADMIN_PASSWORD=your-admin-password
PINGAM_CONNECTION_TIMEOUT=30000
PINGAM_VERIFY_SSL=true

# Sync Settings (E-020)
SYNC_ENABLED=true
SYNC_INTERVAL_SECONDS=300
SYNC_BATCH_SIZE=1000

# Data Retention (E-020)
RETENTION_AUTH_EVENTS_DAYS=90
RETENTION_SESSIONS_DAYS=30
RETENTION_API_LOGS_DAYS=14
RETENTION_ALERTS_DAYS=180
